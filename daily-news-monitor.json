      "name": "Fetch News"
    },
    {
      "parameters": {
        "jsCode": "const response = $input.first().json;\nconst articles = response.articles || [];\n\nreturn articles.map(article => ({\n  json: {\n    title: article.title || 'No title',\n    description: article.description || \n                 'No description',\n    url: article.url || '',\n    publishedAt: article.publishedAt || '',\n    source: article.source?.name || \n            'Unknown'\n  }\n}));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -80,
        -192
      ],
      "id": "bbf65e9d-24d8-4fd5-808f-3f4402e9a60b",
      "name": "Extract Articles"
    },
