      "name": "Recent Only"
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nreturn items.map(item => {\n  const title = (item.json.title || '')\n    .replace(/[\\n\\r\\t]/g, ' ')\n    .replace(/\"/g, \"'\")\n    .replace(/\\\\/g, '')\n    .trim()\n    .substring(0, 200);\n    \n  const description = (item.json.description || '')\n    .replace(/[\\n\\r\\t]/g, ' ')\n    .replace(/\"/g, \"'\")\n    .replace(/\\\\/g, '')\n    .trim()\n    .substring(0, 300);\n\n  return {\n    json: {\n      ...item.json,\n      cleanTitle: title,\n      cleanDescription: description\n    }\n  };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        336,
        -192
      ],
      "id": "64e81c56-3ff4-432a-b00f-26116b8bb342",
      "name": "Clean Data"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.groq.com/openai/v1/chat/completions",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "contentType": "raw",
        "rawContentType": "JSON",
        "body": "={\"model\":\"llama-3.3-70b-versatile\",\"max_tokens\":400,\"temperature\":0.1,\"messages\":[{\"role\":\"system\",\"content\":\"You are a FinTech analyst. Respond ONLY with valid JSON object. No markdown, no explanation, just the JSON.\"},{\"role\":\"user\",\"content\":\"Analyze this FinTech news. Reply ONLY with this JSON: {\\\"company\\\": \\\"name or Unknown\\\", \\\"category\\\": \\\"Pricing or Feature or Funding or Leadership or News or Partnership\\\", \\\"importance\\\": \\\"High or Medium or Low\\\", \\\"summary\\\": \\\"2 sentences about what happened\\\"}. Title: {{ $json.cleanTitle }} Description: {{ $json.cleanDescription }}\"}]}",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        544,
        -192
      ],
      "id": "d9c789b2-d99f-40d8-88c5-a5b32ba8c6fb",
      "name": "HTTP Request",
      "credentials": {
        "httpHeaderAuth": {
          "id": "PKCtxzZ6gKIaVTzF",
          "name": "Header Auth account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst results = [];\n\nfor (const item of items) {\n  const content = item.json.choices[0]\n                  .message.content || '';\n  \n  let parsed;\n  try {\n    const cleaned = content\n      .replace(/```json/g, '')\n      .replace(/```/g, '')\n      .trim();\n    parsed = JSON.parse(cleaned);\n  } catch(e) {\n    parsed = {\n      company: 'Unknown',\n      category: 'News',\n      importance: 'Low',\n      summary: content.substring(0, 200)\n    };\n  }\n\n  results.push({\n    json: {\n      company: parsed.company || 'Unknown',\n      category: parsed.category || 'News',\n      importance: parsed.importance || 'Low',\n      summary: parsed.summary || '',\n      title: $('Clean Data').item.json.title,\n      url: $('Clean Data').item.json.url,\n      publishedAt: $('Clean Data')\n                   .item.json.publishedAt\n    }\n  });\n}\n\nreturn results;"
      },
